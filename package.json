{
  "name": "iris",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch --env-file=.env.local server/index.ts",
    "dev:client": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "secrets:put": "wrangler secret put ANTHROPIC_API_KEY && wrangler secret put ELEVENLABS_API_KEY",
    "seed:goethe": "tsx scripts/seed/goethe.ts",
    "seed:tatoeba": "tsx scripts/seed/tatoeba.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "express": "^4.21.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.18.6",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wrangler": "^4.85.0"
  }
}
